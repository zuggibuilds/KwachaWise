# Example environment variables for KwachaWise server
# Copy to .env and fill values (DO NOT commit secrets)

# Server
SERVER_PORT=4000

# Database
DATABASE_PATH=./data/kwachawise.sqlite

# JWT secret (generate a long random value)
JWT_SECRET=replace-with-strong-secret

# Client origin (exact origin for production)
CLIENT_ORIGIN=http://localhost:5173

# Optional: set to 'production' in production
NODE_ENV=development

# Optional Sentry settings
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

